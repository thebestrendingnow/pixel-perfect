# ============================================================
# Travel AI PFR — Environment Variables
# Copy this file to .dev.vars for local development
# Set production secrets via: npx wrangler pages secret put KEY_NAME
# ============================================================

# ─── Travelpayouts Affiliate ─────────────────────────────────
# Already included — your affiliate credentials
TRAVELPAYOUTS_API_KEY=140003fe70f6a86ab4b3d538bafb7c42
TRAVELPAYOUTS_MARKER=314682

# ─── AI Chat (LaoZhang / KIE.ai) ────────────────────────────
# Get your key at: https://api.laozhang.ai or https://api.kie.ai
LAOZHANG_API_KEY=your-laozhang-or-kie-api-key-here

# ─── Voice TTS (ElevenLabs) ──────────────────────────────────
# Get your key at: https://elevenlabs.io/api
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
# Optional: override default voice (default = Bella, a warm female voice)
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# ─── Payments (Stripe) ───────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret

# ─── Subscriptions (Whop) ────────────────────────────────────
# https://whop.com/hub/
WHOP_API_KEY=your-whop-api-key
WHOP_WEBHOOK_SECRET=your-whop-webhook-signing-secret

# ─── JWT Auth ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-256-bit-string-in-production

# ─── Email (Resend) ──────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ─── Google Places (optional, for reviews) ───────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ─── Amadeus Hotels (optional, secondary hotel source) ───────
# https://developers.amadeus.com/
AMADEUS_CLIENT_ID=your-amadeus-client-id
AMADEUS_CLIENT_SECRET=your-amadeus-client-secret

# ─── White-Label Branding (all optional — have defaults) ─────
# Set these to fully rebrand the app for your domain/brand
SITE_NAME=Travel AI PFR
SITE_TAGLINE=Best Hotel Deals — AI-Powered Search
SITE_URL=https://yourdomain.com
LOGO_URL=https://yourdomain.com/logo.png
FAVICON_URL=https://yourdomain.com/favicon.ico

# ─── White-Label Colors (Ocean Deep defaults) ────────────────
# Replace with your brand hex colors
COLOR_PRIMARY=#2d8a9e
COLOR_SECONDARY=#0c2340
COLOR_ACCENT=#5cbdb9
COLOR_BG_DARK=#0c2340

# ─── Contact & Legal ─────────────────────────────────────────
SUPPORT_EMAIL=support@yourdomain.com
PRIVACY_URL=https://yourdomain.com/privacy
TERMS_URL=https://yourdomain.com/terms

# ─── Social Media (optional) ─────────────────────────────────
TWITTER_URL=https://twitter.com/yourhandle
INSTAGRAM_URL=https://instagram.com/yourhandle

# ─── Feature Toggles (set to 'false' to disable) ────────────
SHOW_DRIVER_MODE=true
SHOW_VOICE_CHAT=true
SHOW_PRICE_COMPARISON=true
SHOW_MAP=true
