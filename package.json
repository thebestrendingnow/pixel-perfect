{
  "name": "travel-payout-hotels",
  "type": "module",
  "version": "1.0.0",
  "description": "Travel Payout Hotel Finder - AI-powered hotel search with affiliate commissions",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "dev:d1": "wrangler pages dev dist --d1=travel-payout-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name travel-payout-hotels",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply travel-payout-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply travel-payout-production",
    "db:seed": "wrangler d1 execute travel-payout-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "db:console": "wrangler d1 execute travel-payout-production --local",
    "db:console:prod": "wrangler d1 execute travel-payout-production",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "test": "curl -s http://localhost:3000/api/health | python3 -m json.tool"
  },
  "dependencies": {
    "hono": "^4.12.12",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250705.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
