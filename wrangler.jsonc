{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "travel-payout-hotels",
  "compatibility_date": "2026-04-13",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "travel-payout-production",
      "database_id": "2a540081-e76c-4c7f-aa25-c455931d779a"
    }
  ],

  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "travel-payout-media"
    }
  ]
}
